---
// OutOfStateNCInvestors.com | Dennis Fields | Movement Mortgage | NMLS #1407951
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Free NC Investor Guide | OutOfStateNCInvestors.com</title>
<meta name="description" content="Discover how smart investors from NYC, LA & Chicago are quietly building wealth in North Carolina. Download the free guide from Dennis Fields, Movement Mortgage.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400;1,600&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,700&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --navy: #1B3A6B;
  --navy-deep: #0d1f3c;
  --navy-darker: #070f1e;
  --gold: #C9A84C;
  --gold-light: #e8c975;
  --gold-pale: rgba(201,168,76,0.12);
  --cream: #FDF8F0;
  --white: #ffffff;
  --mid: #94a3b8;
  --border: rgba(255,255,255,0.08);
  --green: #10b981;
}

html { scroll-behavior: smooth; }

body {
  font-family: 'DM Sans', sans-serif;
  background: var(--navy-darker);
  color: var(--white);
  overflow-x: hidden;
  cursor: default;
}

/* ── NOISE TEXTURE OVERLAY ── */
body::before {
  content: '';
  position: fixed;
  inset: 0;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
  pointer-events: none;
  z-index: 0;
  opacity: 0.4;
}

/* ── NAV ── */
nav {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 100;
  padding: 18px 40px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(to bottom, rgba(7,15,30,0.95) 0%, transparent 100%);
  backdrop-filter: blur(8px);
}
.nav-logo {
  font-family: 'Cormorant Garamond', serif;
  font-size: 18px;
  font-weight: 700;
  color: var(--white);
  letter-spacing: 0.5px;
}
.nav-logo span { color: var(--gold); }
.nav-cta {
  background: var(--gold);
  color: var(--navy-deep);
  padding: 9px 22px;
  border-radius: 30px;
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  text-decoration: none;
  transition: all 0.2s;
}
.nav-cta:hover { background: var(--gold-light); transform: translateY(-1px); }

/* ── HERO ── */
.hero {
  position: relative;
  min-height: 100vh;
  display: flex;
  align-items: center;
  overflow: hidden;
  padding: 120px 40px 80px;
}

/* Diagonal geometric background */
.hero::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    linear-gradient(135deg, var(--navy-deep) 0%, var(--navy-darker) 60%),
    radial-gradient(ellipse 80% 60% at 70% 40%, rgba(27,58,107,0.6) 0%, transparent 70%);
  z-index: 0;
}
.hero-geo {
  position: absolute;
  right: -5%;
  top: 50%;
  transform: translateY(-50%);
  width: 55%;
  height: 120%;
  background: linear-gradient(135deg, rgba(27,58,107,0.4) 0%, rgba(201,168,76,0.06) 100%);
  clip-path: polygon(15% 0%, 100% 0%, 100% 100%, 0% 100%);
  z-index: 0;
}
.hero-geo::after {
  content: '';
  position: absolute;
  inset: 1px;
  background: linear-gradient(135deg, rgba(201,168,76,0.04), transparent 60%);
  clip-path: polygon(15% 0%, 100% 0%, 100% 100%, 0% 100%);
}

/* Animated gold lines */
.hero-lines {
  position: absolute;
  right: 8%;
  top: 50%;
  transform: translateY(-50%);
  width: 42%;
  height: 70%;
  z-index: 1;
  opacity: 0.15;
}
.hero-lines::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    repeating-linear-gradient(
      -45deg,
      transparent,
      transparent 40px,
      rgba(201,168,76,0.5) 40px,
      rgba(201,168,76,0.5) 41px
    );
}

.hero-inner {
  position: relative;
  z-index: 2;
  max-width: 1200px;
  margin: 0 auto;
  width: 100%;
  display: grid;
  grid-template-columns: 1fr 500px;
  gap: 60px;
  align-items: center;
}

/* Left — copy */
.hero-copy { animation: fadeUp 0.8s ease both; }
@keyframes fadeUp { from { opacity:0; transform:translateY(30px); } to { opacity:1; transform:translateY(0); } }

.hero-eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 4px;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 24px;
}
.hero-eyebrow::before {
  content: '';
  display: block;
  width: 32px;
  height: 1px;
  background: var(--gold);
}

.hero-h1 {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(42px, 5.5vw, 72px);
  font-weight: 700;
  line-height: 1.0;
  color: var(--white);
  margin-bottom: 16px;
}
.hero-h1 em {
  font-style: italic;
  color: var(--gold);
}

.hero-sub {
  font-size: 17px;
  font-weight: 300;
  color: var(--mid);
  line-height: 1.65;
  max-width: 480px;
  margin-bottom: 40px;
}
.hero-sub strong { color: rgba(255,255,255,0.85); font-weight: 500; }

/* Social proof strip */
.proof-strip {
  display: flex;
  gap: 28px;
  flex-wrap: wrap;
  margin-bottom: 40px;
  animation: fadeUp 0.8s 0.2s ease both;
}
.proof-item {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 12px;
  color: var(--mid);
}
.proof-dot {
  width: 6px; height: 6px;
  border-radius: 50%;
  background: var(--gold);
  flex-shrink: 0;
}

/* Squawk Box quote */
.quote-pull {
  border-left: 2px solid var(--gold);
  padding: 14px 20px;
  margin-bottom: 40px;
  background: rgba(201,168,76,0.06);
  border-radius: 0 8px 8px 0;
  animation: fadeUp 0.8s 0.3s ease both;
}
.quote-pull p {
  font-family: 'Cormorant Garamond', serif;
  font-size: 16px;
  font-style: italic;
  color: rgba(255,255,255,0.85);
  line-height: 1.5;
  margin-bottom: 6px;
}
.quote-pull cite {
  font-size: 10px;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--gold);
  font-style: normal;
}

/* ── FORM CARD ── */
.form-card {
  background: rgba(255,255,255,0.03);
  border: 1px solid rgba(201,168,76,0.25);
  border-radius: 20px;
  padding: 36px 32px;
  backdrop-filter: blur(12px);
  animation: fadeUp 0.8s 0.15s ease both;
  position: relative;
  overflow: hidden;
}

/* GHL form iframe wrapper */
.ghl-form-wrap {
  border-radius: 12px;
  overflow: hidden;
  border: 1px solid rgba(255,255,255,0.08);
  background: #fff;
}
.form-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 3px;
  background: linear-gradient(to right, var(--gold), var(--gold-light), var(--gold));
}
.form-card-badge {
  display: inline-block;
  background: var(--gold-pale);
  border: 1px solid rgba(201,168,76,0.3);
  color: var(--gold);
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 3px;
  text-transform: uppercase;
  padding: 5px 12px;
  border-radius: 20px;
  margin-bottom: 16px;
}
.form-card h3 {
  font-family: 'Cormorant Garamond', serif;
  font-size: 26px;
  font-weight: 700;
  color: var(--white);
  line-height: 1.2;
  margin-bottom: 8px;
}
.form-card p {
  font-size: 13px;
  color: var(--mid);
  margin-bottom: 24px;
  line-height: 1.5;
}

.form-group { margin-bottom: 14px; }
.form-group label {
  display: block;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: rgba(255,255,255,0.5);
  margin-bottom: 7px;
}
.form-group input, .form-group select {
  width: 100%;
  background: rgba(255,255,255,0.05);
  border: 1px solid rgba(255,255,255,0.12);
  border-radius: 10px;
  padding: 13px 16px;
  font-family: 'DM Sans', sans-serif;
  font-size: 14px;
  color: var(--white);
  outline: none;
  transition: border-color 0.2s, background 0.2s;
  appearance: none;
}
.form-group input::placeholder { color: rgba(255,255,255,0.25); }
.form-group input:focus, .form-group select:focus {
  border-color: var(--gold);
  background: rgba(201,168,76,0.05);
}
.form-group select option { background: var(--navy-deep); color: var(--white); }

.submit-btn {
  width: 100%;
  background: linear-gradient(135deg, var(--gold) 0%, #a8832a 100%);
  color: var(--navy-deep);
  border: none;
  border-radius: 12px;
  padding: 16px 24px;
  font-family: 'DM Sans', sans-serif;
  font-size: 14px;
  font-weight: 700;
  letter-spacing: 1px;
  text-transform: uppercase;
  cursor: pointer;
  transition: all 0.25s;
  margin-top: 6px;
  box-shadow: 0 6px 24px rgba(201,168,76,0.3);
}
.submit-btn:hover {
  transform: translateY(-2px);
  box-shadow: 0 10px 32px rgba(201,168,76,0.45);
}
.submit-btn:active { transform: translateY(0); }

.form-disclaimer {
  font-size: 10px;
  color: rgba(255,255,255,0.25);
  text-align: center;
  margin-top: 12px;
  line-height: 1.5;
}

/* What's inside checklist */
.inside-list {
  list-style: none;
  margin-top: 20px;
  border-top: 1px solid var(--border);
  padding-top: 18px;
}
.inside-list li {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  font-size: 12px;
  color: rgba(255,255,255,0.6);
  padding: 5px 0;
}
.inside-list li::before {
  content: '✓';
  color: var(--gold);
  font-weight: 700;
  font-size: 13px;
  flex-shrink: 0;
  margin-top: 1px;
}

/* ── SUCCESS STATE ── */
.success-state {
  display: none;
  text-align: center;
  padding: 20px 0;
}
.success-icon {
  width: 64px; height: 64px;
  background: rgba(16,185,129,0.15);
  border: 1px solid rgba(16,185,129,0.3);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28px;
  margin: 0 auto 16px;
}
.success-state h3 {
  font-family: 'Cormorant Garamond', serif;
  font-size: 26px;
  color: var(--white);
  margin-bottom: 8px;
}
.success-state p { font-size: 13px; color: var(--mid); margin-bottom: 24px; line-height: 1.5; }
.calendly-btn {
  display: inline-block;
  background: linear-gradient(135deg, var(--gold), #a8832a);
  color: var(--navy-deep);
  padding: 14px 28px;
  border-radius: 10px;
  font-size: 13px;
  font-weight: 700;
  letter-spacing: 1px;
  text-transform: uppercase;
  text-decoration: none;
  transition: all 0.2s;
  box-shadow: 0 6px 20px rgba(201,168,76,0.3);
}
.calendly-btn:hover { transform: translateY(-2px); box-shadow: 0 10px 28px rgba(201,168,76,0.45); }

/* ── SOCIAL PROOF BAR ── */
.proof-bar {
  position: relative;
  z-index: 2;
  background: rgba(255,255,255,0.03);
  border-top: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
  padding: 28px 40px;
  display: flex;
  justify-content: center;
  gap: 60px;
  flex-wrap: wrap;
}
.proof-stat { text-align: center; }
.proof-stat .ps-value {
  font-family: 'Cormorant Garamond', serif;
  font-size: 36px;
  font-weight: 700;
  color: var(--gold);
  line-height: 1;
  margin-bottom: 4px;
}
.proof-stat .ps-label {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--mid);
}

/* ── MARKETS SECTION ── */
.markets-section {
  position: relative;
  z-index: 2;
  padding: 100px 40px;
  max-width: 1200px;
  margin: 0 auto;
}
.section-label {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 4px;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 12px;
}
.section-h2 {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(34px, 4vw, 52px);
  font-weight: 700;
  color: var(--white);
  line-height: 1.1;
  margin-bottom: 16px;
}
.section-sub {
  font-size: 16px;
  color: var(--mid);
  max-width: 540px;
  margin-bottom: 56px;
  line-height: 1.6;
}

.markets-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 16px;
}
.market-tile {
  background: rgba(255,255,255,0.03);
  border: 1px solid var(--border);
  border-radius: 16px;
  padding: 28px 22px;
  transition: all 0.25s;
  position: relative;
  overflow: hidden;
}
.market-tile::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 2px;
  background: linear-gradient(to right, var(--gold), transparent);
  opacity: 0;
  transition: opacity 0.25s;
}
.market-tile:hover {
  border-color: rgba(201,168,76,0.3);
  background: rgba(201,168,76,0.04);
  transform: translateY(-4px);
}
.market-tile:hover::before { opacity: 1; }
.market-tile .mt-city {
  font-family: 'Cormorant Garamond', serif;
  font-size: 20px;
  font-weight: 700;
  color: var(--white);
  margin-bottom: 4px;
}
.market-tile .mt-region {
  font-size: 11px;
  color: var(--mid);
  margin-bottom: 20px;
}
.market-tile .mt-stat-val {
  font-size: 28px;
  font-weight: 700;
  color: var(--gold);
  line-height: 1;
  margin-bottom: 3px;
}
.market-tile .mt-stat-label {
  font-size: 10px;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  color: var(--mid);
  margin-bottom: 16px;
}
.market-tile .mt-tag {
  display: inline-block;
  background: rgba(201,168,76,0.12);
  border: 1px solid rgba(201,168,76,0.2);
  color: var(--gold);
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 2px;
  text-transform: uppercase;
  padding: 4px 10px;
  border-radius: 20px;
}

/* ── ABOUT DENNIS ── */
.about-section {
  position: relative;
  z-index: 2;
  background: rgba(255,255,255,0.02);
  border-top: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
  padding: 100px 40px;
}
.about-inner {
  max-width: 1200px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 80px;
  align-items: center;
}
.about-img-wrap {
  position: relative;
}
.about-img-placeholder {
  width: 100%;
  aspect-ratio: 4/5;
  background: linear-gradient(135deg, var(--navy) 0%, var(--navy-deep) 100%);
  border-radius: 20px;
  border: 1px solid rgba(201,168,76,0.2);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12px;
  position: relative;
  overflow: hidden;
}
.about-img-placeholder::before {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(circle at 50% 30%, rgba(201,168,76,0.1), transparent 70%);
}
.about-img-placeholder .initials {
  font-family: 'Cormorant Garamond', serif;
  font-size: 72px;
  font-weight: 700;
  color: var(--gold);
  opacity: 0.6;
  position: relative;
}
.about-img-placeholder .img-label {
  font-size: 11px;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--mid);
  position: relative;
}
.about-badge {
  position: absolute;
  bottom: -16px;
  right: -16px;
  background: var(--gold);
  color: var(--navy-deep);
  padding: 16px 20px;
  border-radius: 14px;
  text-align: center;
  box-shadow: 0 8px 32px rgba(201,168,76,0.4);
}
.about-badge .ab-val {
  font-family: 'Cormorant Garamond', serif;
  font-size: 32px;
  font-weight: 700;
  line-height: 1;
}
.about-badge .ab-label {
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 2px;
  text-transform: uppercase;
  opacity: 0.75;
  margin-top: 3px;
}

.about-copy { }
.about-copy .section-label { margin-bottom: 12px; }
.about-copy .section-h2 { margin-bottom: 20px; }
.about-copy p {
  font-size: 15px;
  color: rgba(255,255,255,0.65);
  line-height: 1.7;
  margin-bottom: 16px;
}
.about-copy p strong { color: rgba(255,255,255,0.9); font-weight: 500; }

.credential-list {
  list-style: none;
  margin-top: 28px;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
}
.credential-list li {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 12px;
  color: var(--mid);
}
.credential-list li::before {
  content: '→';
  color: var(--gold);
  flex-shrink: 0;
}

/* ── WHAT'S INSIDE ── */
.inside-section {
  position: relative;
  z-index: 2;
  padding: 100px 40px;
  max-width: 1200px;
  margin: 0 auto;
}
.chapters-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  gap: 14px;
  margin-top: 48px;
}
.chapter-item {
  display: flex;
  align-items: flex-start;
  gap: 16px;
  background: rgba(255,255,255,0.03);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 20px 18px;
  transition: all 0.2s;
}
.chapter-item:hover {
  border-color: rgba(201,168,76,0.25);
  background: rgba(201,168,76,0.03);
}
.ch-num {
  font-family: 'Cormorant Garamond', serif;
  font-size: 28px;
  font-weight: 700;
  color: rgba(201,168,76,0.3);
  line-height: 1;
  flex-shrink: 0;
  width: 36px;
}
.ch-title {
  font-size: 13px;
  font-weight: 500;
  color: rgba(255,255,255,0.8);
  line-height: 1.4;
}

/* ── FINAL CTA ── */
.final-cta {
  position: relative;
  z-index: 2;
  padding: 120px 40px;
  text-align: center;
  overflow: hidden;
}
.final-cta::before {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse 80% 60% at 50% 50%, rgba(27,58,107,0.5), transparent 70%);
  pointer-events: none;
}
.final-cta .section-h2 { margin: 0 auto 16px; max-width: 700px; }
.final-cta .section-sub { margin: 0 auto 48px; }

.final-form {
  display: flex;
  gap: 12px;
  max-width: 480px;
  margin: 0 auto 16px;
  position: relative;
}
.final-form input {
  flex: 1;
  background: rgba(255,255,255,0.06);
  border: 1px solid rgba(255,255,255,0.15);
  border-radius: 12px;
  padding: 15px 20px;
  font-family: 'DM Sans', sans-serif;
  font-size: 14px;
  color: var(--white);
  outline: none;
  transition: border-color 0.2s;
}
.final-form input:focus { border-color: var(--gold); }
.final-form input::placeholder { color: rgba(255,255,255,0.3); }
.final-form button {
  background: linear-gradient(135deg, var(--gold), #a8832a);
  color: var(--navy-deep);
  border: none;
  border-radius: 12px;
  padding: 15px 24px;
  font-family: 'DM Sans', sans-serif;
  font-size: 13px;
  font-weight: 700;
  letter-spacing: 1px;
  text-transform: uppercase;
  cursor: pointer;
  white-space: nowrap;
  transition: all 0.2s;
  box-shadow: 0 4px 20px rgba(201,168,76,0.3);
}
.final-form button:hover { transform: translateY(-2px); box-shadow: 0 8px 28px rgba(201,168,76,0.45); }

/* ── FOOTER ── */
footer {
  position: relative;
  z-index: 2;
  border-top: 1px solid var(--border);
  padding: 40px;
  text-align: center;
}
footer .f-name {
  font-family: 'Cormorant Garamond', serif;
  font-size: 20px;
  font-weight: 700;
  color: var(--white);
  margin-bottom: 6px;
}
footer p {
  font-size: 11px;
  color: rgba(255,255,255,0.35);
  line-height: 1.8;
}
footer a { color: var(--gold); text-decoration: none; }
footer .disclaimer {
  font-size: 10px;
  color: rgba(255,255,255,0.2);
  margin-top: 16px;
  max-width: 600px;
  margin-left: auto;
